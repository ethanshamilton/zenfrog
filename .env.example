# Required to use Moonshot AI models.
# MOONSHOT_API_KEY=your_moonshot_api_key

# Local journal data config for Tauri dev.
# Copy to .env and update paths. Real environment variables still take precedence.

ZENFROG_JOURNAL_DIR=/Users/you/OneDrive/Journal/Daily Pages
ZENFROG_EVERGREEN_DIR=/Users/you/OneDrive/Journal/Evergreen
ZENFROG_EMBEDDINGS_PATH=/Users/you/OneDrive/Journal/embeddings.jsonl
# ZENFROG_CHATS_PATH=/Users/you/path/to/chats.json
# Defaults to sibling of ZENFROG_JOURNAL_DIR, e.g. /Users/you/OneDrive/Journal/Personalities
# ZENFROG_PERSONALITY_DIR=/Users/you/OneDrive/Journal/Personalities
